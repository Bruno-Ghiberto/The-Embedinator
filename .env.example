# The Embedinator — Environment Variables
# Copy to .env and customize as needed. Defaults are local-first.

# -- Ollama --
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LLM_MODEL=qwen2.5:7b
DEFAULT_EMBED_MODEL=nomic-embed-text

# -- Qdrant --
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# -- Backend --
HOST=0.0.0.0
PORT=8000
SQLITE_PATH=./data/embedinator.db
LOG_LEVEL=INFO
DEBUG=false

# -- Frontend --
FRONTEND_PORT=3000

# -- Security --
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required for production; auto-generated dev fallback if unset.
EMBEDINATOR_FERNET_KEY=

# -- Agent Limits --
MAX_ITERATIONS=10
MAX_TOOL_CALLS=8
CONFIDENCE_THRESHOLD=60
# MetaReasoningGraph: mean cross-encoder score below which retrieval is "poor"
META_RELEVANCE_THRESHOLD=0.2
# MetaReasoningGraph: stdev above which results are "noisy"
META_VARIANCE_THRESHOLD=0.15

# -- Retrieval --
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# -- CORS --
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
